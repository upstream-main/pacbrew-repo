pkgname=ps5-payload-rmlui
pkgver=6.2
pkgrel=1
pkgdesc='A HTML/CSS User Interface library'
arch=('any')
url='https://mikke89.github.io/RmlUiDoc'
license=('MIT')
source=("https://github.com/mikke89/RmlUi/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('814c3ff7b9666280338d8f0dda85979f5daf028d01c85fc8975431d1e2fd8e8b')
options=(!strip libtool staticlibs)
groups=('ps5-payload-dev')
makedepends=('ps5-payload-sdk' 'ps5-payload-libcxx' 'ps5-payload-luajit'
	     'ps5-payload-freetype' 'ps5-payload-sdl2' 'ps5-payload-sdl2_image')

prepare() {
    if [ -z "${PS5_PAYLOAD_SDK}" ]; then
	export PS5_PAYLOAD_SDK=/opt/ps5-payload-sdk
    fi
}

build() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd RmlUi-$pkgver

    ${CMAKE} -DCMAKE_BUILD_TYPE=Release \
	     -DRMLUI_LUA_BINDINGS=YES \
	     -DRML_LUA_BINDINGS_LIBRARY=luajit \
	     -B build \
             -S .
    ${MAKE} -C build
}

package() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd RmlUi-$pkgver

    export DESTDIR="${pkgdir}/${DESTDIR}"
    ${MAKE} -C build install

    ${PS5_CROSS_FIX_ROOT} "${DESTDIR}/${PREFIX}"
}
