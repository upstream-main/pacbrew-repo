pkgname=ps5-payload-libminizip
pkgver=1.3.2
pkgrel=1
pkgdesc='Deflate compression method library'
arch=('any')
url='http://www.zlib.net/'
license=('zlib')
options=(!strip libtool staticlibs)
source=("https://zlib.net/zlib-$pkgver.tar.gz")
sha256sums=('bb329a0a2cd0274d05519d61c667c062e06990d72e125ee2dfa8de64f0119d16')
groups=('ps5-payload-dev')
makedepends=('ps5-payload-sdk' 'ps5-payload-zlib')

prepare() {
    if [ -z "${PS5_PAYLOAD_SDK}" ]; then
	export PS5_PAYLOAD_SDK=/opt/ps5-payload-sdk
    fi
    cd zlib-$pkgver/contrib/minizip
    sed -i 's|"shared"||g' minizipConfig.cmake.in
}

build() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd zlib-$pkgver/contrib/minizip

    ${CMAKE} -DCMAKE_BUILD_TYPE=Release \
	     -DMINIZIP_BUILD_STATIC=YES \
	     -DMINIZIP_BUILD_SHARED=NO \
	     -DMINIZIP_INSTALL=YES \
	     -B build \
             -S .
    ${MAKE} -C build
}

package() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd zlib-$pkgver/contrib/minizip

    export DESTDIR="${pkgdir}/${DESTDIR}"
    ${MAKE} -C build install
}
